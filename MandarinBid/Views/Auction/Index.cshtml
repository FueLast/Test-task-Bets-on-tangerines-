@model List<MandarinBid.Models.Mandarin>

<h2>Аукцион мандаринок</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3">
            <div class="card mb-3">
                <div class="card-body">
                    <h5>@item.Name</h5>

                    <p>Цена: @item.CurrentPrice ₽</p>
                    <p>До: @item.ExpirationDate</p>

                    @if (TempData["Error"] != null &&
                        TempData["SuccessMandarinId"]?.ToString() == item.Id.ToString())
                    {
                        <div class="alert alert-danger">
                            @TempData["Error"]
                        </div>
                    }

                    @if (TempData["Success"] != null &&
                        TempData["SuccessMandarinId"]?.ToString() == item.Id.ToString())
                    {
                        <div class="alert alert-success">
                            @TempData["Success"]
                        </div>
                    }

                    @if (item.Bids != null && item.Bids.Any())
                    {
                        var topBid = item.Bids.OrderByDescending(b => b.Amount).First();

                        <p>Лидер: @topBid.UserId</p>
                    }

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Auction" asp-action="PlaceBid" method="post">

                            <input type="hidden" name="mandarinId" value="@item.Id" />
                    
                            <input type="number" step="0.01" name="amount" class="form-control mb-2" placeholder="твоя ставка" />
                    
                            <button type="submit" class="btn btn-success">Сделать ставку</button>

                        </form>
                    }
                    else
                    {
                        <p>войдите чтобы делать ставки</p>
                    }

                    @if (item.Bids != null && item.Bids.Any())
                    {
                        var orderedBids = item.Bids
                            .OrderByDescending(b => b.Amount) //сортировка
                            .Take(5) // ограничение
                            .ToList();

                        <hr />
                        <p><strong>Топ ставок:</strong></p>

                        <ul class="list-group">
                            @foreach (var bid in orderedBids) // подсветка лидера
                            {
                                var isTop = bid == orderedBids.First();

                                <li class="list-group-item d-flex justify-content-between @(isTop ? "list-group-item-success" : "")">
                                    <span>@bid.UserId</span>
                                    <span>@bid.Amount ₽</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>Пока нет ставок</p>
                    }

 


                </div>
            </div>
        </div>
    }
</div>