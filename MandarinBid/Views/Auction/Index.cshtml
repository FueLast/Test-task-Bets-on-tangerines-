@model List<MandarinBid.Models.Mandarin>

<h2>Аукцион мандаринок</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3">
            <div class="card mb-3">
                <div class="card-body">
                    <h5>@item.Name</h5>

                    <p>Цена: @item.CurrentPrice ₽</p>
                    <p>До: @item.ExpirationDate</p>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Auction" asp-action="PlaceBid" method="post">
                            <input type="hidden" name="mandarinId" value="@item.Id" />

                            <input type="number" step="0.01" name="amount" class="form-control mb-2" placeholder="Ваша ставка" />

                            <button type="submit" class="btn btn-primary">
                                Сделать ставку
                            </button>
                        </form>
                    }
                    else
                    {
                        <p>Войдите, чтобы сделать ставку</p>
                    }
                </div>
            </div>
        </div>
    }
</div>